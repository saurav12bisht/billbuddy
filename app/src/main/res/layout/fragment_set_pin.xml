<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        style="@style/Widget.Vyapaar.Toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="?attr/actionBarSize"
        app:navigationIcon="@drawable/ic_back_white"
        app:title="@string/app_lock"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvPinTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter PIN"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginHorizontal="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        android:layout_marginTop="48dp" />

    <TextView
        android:id="@+id/tvPinSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter a 4-digit PIN"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:alpha="0.8"
        android:layout_marginHorizontal="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvPinTitle"
        android:layout_marginTop="8dp" />

    <LinearLayout
        android:id="@+id/pinDots"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginHorizontal="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvPinSubtitle"
        android:layout_marginTop="32dp">
        <View android:id="@+id/dot1" android:layout_width="24dp" android:layout_height="24dp" android:layout_marginEnd="16dp" android:background="@drawable/pin_dot_empty" />
        <View android:id="@+id/dot2" android:layout_width="24dp" android:layout_height="24dp" android:layout_marginEnd="16dp" android:background="@drawable/pin_dot_empty" />
        <View android:id="@+id/dot3" android:layout_width="24dp" android:layout_height="24dp" android:layout_marginEnd="16dp" android:background="@drawable/pin_dot_empty" />
        <View android:id="@+id/dot4" android:layout_width="24dp" android:layout_height="24dp" android:background="@drawable/pin_dot_empty" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PINs do not match"
        android:textColor="@color/accent_red"
        android:visibility="gone"
        android:layout_marginHorizontal="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/pinDots"
        android:layout_marginTop="8dp" />

    <LinearLayout
        android:id="@+id/numpad"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginHorizontal="24dp"
        app:layout_constraintBottom_toTopOf="@id/btnSave"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvError"
        android:layout_marginTop="48dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <com.google.android.material.button.MaterialButton android:id="@+id/btn1" android:layout_width="0dp" android:layout_height="72dp" android:layout_weight="1" android:layout_margin="4dp" android:text="1" style="@style/Widget.Material3.Button.OutlinedButton" android:textColor="@color/white" app:strokeColor="@color/white" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btn2" android:layout_width="0dp" android:layout_height="72dp" android:layout_weight="1" android:layout_margin="4dp" android:text="2" style="@style/Widget.Material3.Button.OutlinedButton" android:textColor="@color/white" app:strokeColor="@color/white" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btn3" android:layout_width="0dp" android:layout_height="72dp" android:layout_weight="1" android:layout_margin="4dp" android:text="3" style="@style/Widget.Material3.Button.OutlinedButton" android:textColor="@color/white" app:strokeColor="@color/white" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <com.google.android.material.button.MaterialButton android:id="@+id/btn4" android:layout_width="0dp" android:layout_height="72dp" android:layout_weight="1" android:layout_margin="4dp" android:text="4" style="@style/Widget.Material3.Button.OutlinedButton" android:textColor="@color/white" app:strokeColor="@color/white" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btn5" android:layout_width="0dp" android:layout_height="72dp" android:layout_weight="1" android:layout_margin="4dp" android:text="5" style="@style/Widget.Material3.Button.OutlinedButton" android:textColor="@color/white" app:strokeColor="@color/white" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btn6" android:layout_width="0dp" android:layout_height="72dp" android:layout_weight="1" android:layout_margin="4dp" android:text="6" style="@style/Widget.Material3.Button.OutlinedButton" android:textColor="@color/white" app:strokeColor="@color/white" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <com.google.android.material.button.MaterialButton android:id="@+id/btn7" android:layout_width="0dp" android:layout_height="72dp" android:layout_weight="1" android:layout_margin="4dp" android:text="7" style="@style/Widget.Material3.Button.OutlinedButton" android:textColor="@color/white" app:strokeColor="@color/white" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btn8" android:layout_width="0dp" android:layout_height="72dp" android:layout_weight="1" android:layout_margin="4dp" android:text="8" style="@style/Widget.Material3.Button.OutlinedButton" android:textColor="@color/white" app:strokeColor="@color/white" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btn9" android:layout_width="0dp" android:layout_height="72dp" android:layout_weight="1" android:layout_margin="4dp" android:text="9" style="@style/Widget.Material3.Button.OutlinedButton" android:textColor="@color/white" app:strokeColor="@color/white" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <com.google.android.material.button.MaterialButton android:id="@+id/btn0" android:layout_width="0dp" android:layout_height="72dp" android:layout_weight="1" android:layout_margin="4dp" android:text="0" style="@style/Widget.Material3.Button.OutlinedButton" android:textColor="@color/white" app:strokeColor="@color/white" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBackspace"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="âŒ«"
                android:textSize="24sp"
                android:textColor="@color/white"
                app:strokeColor="@color/white" />
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/save"
        android:textSize="16sp"
        android:textColor="@color/white"
        android:enabled="false"
        app:backgroundTint="@color/primary_variant"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="32dp"
        android:layout_marginHorizontal="24dp" />
</androidx.constraintlayout.widget.ConstraintLayout>
