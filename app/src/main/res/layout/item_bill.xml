<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    app:cardBackgroundColor="@color/card_surface"
    app:strokeWidth="0dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingEnd="16dp"
        android:paddingVertical="16dp">

        <!-- Left Border Accent -->
        <View
            android:id="@+id/vBorderAccent"
            android:layout_width="3dp"
            android:layout_height="0dp"
            android:background="@color/primary_blue"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Icon container -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/iconContainer"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="16dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#331A6FC4"
            app:layout_constraintStart_toEndOf="@id/vBorderAccent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/ivCategoryIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_summary"
                app:tint="@color/primary_blue"
                android:contentDescription="@null" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Bill Name -->
        <TextView
            android:id="@+id/tvBillTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="8dp"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:fontFamily="@font/poppins_medium"
            app:layout_constraintStart_toEndOf="@id/iconContainer"
            app:layout_constraintTop_toTopOf="@id/iconContainer"
            app:layout_constraintBottom_toTopOf="@id/tvBillDate"
            app:layout_constraintEnd_toStartOf="@id/tvBillAmount"
            app:layout_constraintVertical_chainStyle="packed"
            tools:text="Internet Bill" />

        <!-- Bill Date & SMS Badge -->
        <LinearLayout
            android:id="@+id/tvBillDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintStart_toEndOf="@id/iconContainer"
            app:layout_constraintTop_toBottomOf="@id/tvBillTitle"
            app:layout_constraintBottom_toBottomOf="@id/iconContainer"
            app:layout_constraintEnd_toStartOf="@id/tvBillAmount">

            <TextView
                android:id="@+id/tvDateText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular"
                tools:text="Due 12 Aug" />

            <TextView
                android:id="@+id/tvSmsBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_chip_transparent"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:text="SMS"
                android:textColor="@color/primary_blue"
                android:textSize="9sp"
                android:fontFamily="@font/poppins_bold"
                android:visibility="gone"
                tools:visibility="visible" />
        </LinearLayout>

        <!-- Right Side: Amount -->
        <TextView
            android:id="@+id/tvBillAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:fontFamily="@font/poppins_bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/iconContainer"
            app:layout_constraintBottom_toTopOf="@id/tvBillStatusLabel"
            app:layout_constraintVertical_chainStyle="packed"
            tools:text="$45.00" />

        <!-- Urgency Badge -->
        <TextView
            android:id="@+id/tvBillStatusLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_chip_transparent"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:textColor="@color/primary_blue"
            android:textSize="10sp"
            android:fontFamily="@font/poppins_bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvBillAmount"
            app:layout_constraintBottom_toBottomOf="@id/iconContainer"
            tools:text="In 4 days" />
            
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
