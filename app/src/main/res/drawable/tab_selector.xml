<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <layer-list>
            <item android:gravity="center" android:width="12dp" android:height="12dp" android:left="4dp" android:right="4dp">
                <shape android:shape="oval">
                    <solid android:color="@color/primary"/>
                    <size android:width="12dp" android:height="12dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item android:gravity="center" android:width="8dp" android:height="8dp" android:left="4dp" android:right="4dp">
                <shape android:shape="oval">
                    <solid android:color="@color/text_secondary"/> <!-- or a lighter gray -->
                    <size android:width="8dp" android:height="8dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
