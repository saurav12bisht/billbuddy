<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <gradient
                android:angle="315"
                android:startColor="@color/gradient_start"
                android:endColor="@color/gradient_end" />
        </shape>
    </item>
    <item android:gravity="top|end" android:right="20dp" android:top="10dp">
        <shape android:shape="oval">
            <size android:width="112dp" android:height="112dp" />
            <solid android:color="@color/white_10" />
        </shape>
    </item>
    <item android:gravity="bottom|start" android:bottom="-26dp" android:left="-18dp">
        <shape android:shape="oval">
            <size android:width="138dp" android:height="138dp" />
            <solid android:color="@color/white_06" />
        </shape>
    </item>
</layer-list>
