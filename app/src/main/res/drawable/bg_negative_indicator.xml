<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_negative_indicator.xml
    ─────────────────────────
    A very subtle white-tinted pill used as the background for the
    "⚠ Negative balance" badge that appears beneath the hero balance number.

    Design rationale:
    - White text on white-tinted background = readable on ANY gradient colour
    - Low opacity (25%) keeps it subtle — it's a hint, not an alarm
    - No dark colours = no ugly black boxes
    - Thin white border adds just enough separation from the gradient
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <solid android:color="#40FFFFFF" />  <!-- white at 25% opacity -->

    <stroke
        android:width="1dp"
        android:color="#60FFFFFF" />     <!-- white at 38% opacity border -->

    <corners android:radius="20dp" />

</shape>